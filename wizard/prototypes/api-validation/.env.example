# Copy to .env (which is gitignored at the repo root) and replace with a
# real API key generated from the SecretAI portal:
#   https://secretai.scrtlabs.com  →  sign in  →  API keys  →  Generate
#
# Or just set the env var directly in your shell — the script reads it
# from the environment, it doesn't load .env itself.
SECRETAI_API_KEY=sk-replace-me

# Optional: override the portal base URL (defaults to the production portal).
# Useful if SecretAI ever stands up a staging environment.
# SECRETAI_BASE_URL=https://secretai.scrtlabs.com
