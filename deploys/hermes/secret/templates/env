# Hermes Agent .env — Secret tier.
# Written to $HERMES_HOME/.env on first boot by the docker-compose seed
# script. chmod 600 inside the container.
#
# Hermes's custom-provider transport reads from OPENAI_API_KEY (or
# LM_API_KEY) when provider=custom. The SecretAI key is substituted
# into the two lines below at render time.

OPENAI_API_KEY=__SECRETAI_API_KEY__
LM_API_KEY=__SECRETAI_API_KEY__

# Telegram bot — long-polling mode (no webhook).
TELEGRAM_BOT_TOKEN=__TELEGRAM_BOT_TOKEN__
TELEGRAM_ALLOWED_USERS=__TELEGRAM_CHAT_ID__
TELEGRAM_HOME_CHANNEL=__TELEGRAM_CHAT_ID__
